# =============================================================
#  FRAMEWORK CONFIGURATION — .env
#  All values here are the DEFAULT.
#  Override per-run via CLI environment variables or Excel sheet.
# =============================================================

# ── Environment ──────────────────────────────────────────────
# Options: dev | staging | prod
ENV=dev

# ── Browser ──────────────────────────────────────────────────
# Options: chromium | firefox | webkit
BROWSER=chromium

# ── Headless Mode ────────────────────────────────────────────
# true = no visible browser window | false = visible (dev/debug)
HEADLESS=true

# ── Base URL ─────────────────────────────────────────────────
BASE_URL=https://www.saucedemo.com

# ── Credentials (default; overridden by Excel per test row) ──
USERNAME=standard_user
PASSWORD=secret_sauce

# ── Timeouts (milliseconds) ───────────────────────────────────
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=30000

# ── Screenshots ───────────────────────────────────────────────
# Options: always | on-failure | never
SCREENSHOT_MODE=always

# ── Reporting ─────────────────────────────────────────────────
REPORT_DIR=reports/html
REPORT_TITLE=Playwright E2E BDD Report
PROJECT_NAME=SauceDemo E2E Suite

# ── Parallel Execution (TestNG-equivalent) ───────────────────
# 1 = sequential | 2..N = parallel workers
PARALLEL_WORKERS=1

# ── Retry on Failure (TestNG IRetryAnalyzer equivalent) ──────
# 0 = no retry | 1..N = number of retries per failed scenario
RETRY_COUNT=1
